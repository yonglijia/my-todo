{
  "name": "todo-app-backend",
  "version": "1.0.0",
  "description": "Backend API for Todo App",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "seed": "ts-node-dev --transpile-only seedData.ts"
